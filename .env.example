# Copy this file to .env and fill in real values before running docker-compose

# Shared JWT secret — must be identical in Core and Token-MS (min 32 chars)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARACTERS

# MSSQL SA password (strong password required by SQL Server)
DB_PASSWORD=YourStrong!Passw0rd

# Redis password
REDIS_PASSWORD=redispassword

# Redmine database
REDMINE_DB_ROOT_PASSWORD=rootpassword
REDMINE_DB_PASSWORD=redminepassword
REDMINE_SECRET_KEY=redmine_secret_key_base_change_me

# Redmine API key — obtained after logging into Redmine as admin
REDMINE_API_KEY=

# ── Demo seed accounts (Token-MS seeds these on first run) ──
# Development defaults — change before any real deployment.
ADMIN_PASSWORD=Admin1234!
EMPLOYEE_PASSWORD=Employee1234!
CUSTOMER_PASSWORD=Customer1234!
# The Agent authenticates with this account; the Agent's own config must match it.
AGENT_PASSWORD=Agent1234!Secret
