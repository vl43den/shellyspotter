@inherits LayoutComponentBase
@inject AuthService Auth

<div class="page">
    <div class="sidebar">
        <NavMenu @rendermode="AppRenderModes.InteractiveServerNoPrerender" />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    // Session restore now happens in each interactive component's OnInitializedAsync
    // (prerender is disabled, so JS interop is available there). No layout-level
    // OnAfterRender restore is needed.
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
