@page "/"
@rendermode AppRenderModes.InteractiveServerNoPrerender
@inject AuthService Auth
@inject CoreApiService Api
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Dashboard — ShellySpotter</PageTitle>

@if (Auth.CurrentUser is null)
{
    <div class="container-fluid py-3"><p class="text-muted">Loading…</p></div>
}
else
{
<div class="container-fluid py-3">
    <h3>Dashboard</h3>
    <p class="text-muted">Welcome, <strong>@Auth.CurrentUser.Username</strong> (@Auth.CurrentUser.Role)</p>

    @if (_rooms.Count == 0)
    {
        <div class="alert alert-info">No rooms assigned. Contact an employee.</div>
    }

    @foreach (var room in _rooms)
    {
        var reading = _latestReadings.GetValueOrDefault(room.Id);
        var alerts = _openAlerts.GetValueOrDefault(room.Id, []);

        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@room.Name</h5>
                <span class="badge @(alerts.Count > 0 ? "bg-danger" : "bg-success")">
                    @(alerts.Count > 0 ? $"{alerts.Count} Alert(s)" : "OK")
                </span>
            </div>
            <div class="card-body">
                @if (reading is null)
                {
                    <p class="text-muted">No sensor data yet.</p>
                }
                else
                {
                    <div class="row g-3">
                        <div class="col-sm-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4">@(reading.DoorOpen ? "🔓" : "🔒")</div>
                                <small class="text-muted">Door</small>
                                <div class="fw-bold @(reading.DoorOpen ? "text-danger" : "text-success")">
                                    @(reading.DoorOpen ? "OPEN" : "Closed")
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4">🌡️</div>
                                <small class="text-muted">Temperature</small>
                                <div class="fw-bold">@(reading.Temperature.HasValue ? $"{reading.Temperature:F1} C" : "N/A")</div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4">🔋</div>
                                <small class="text-muted">Battery</small>
                                <div class="fw-bold">@(reading.BatteryPercent.HasValue ? $"{reading.BatteryPercent}%" : "N/A")</div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4">🕐</div>
                                <small class="text-muted">Last Update</small>
                                <div class="fw-bold small">@reading.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
                            </div>
                        </div>
                    </div>
                }

                @if (alerts.Count > 0)
                {
                    <div class="mt-3">
                        <h6 class="text-danger">Active Alerts</h6>
                        @foreach (var alert in alerts)
                        {
                            <div class="alert alert-warning d-flex justify-content-between align-items-center">
                                <span>@alert.Message</span>
                                <div>
                                    @if (alert.TicketUrl is not null)
                                    {
                                        <a href="@alert.TicketUrl" target="_blank" class="btn btn-sm btn-outline-secondary me-1">Ticket</a>
                                    }
                                    @if (Auth.IsEmployee)
                                    {
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => ResolveAlert(room.Id, alert.Id)">Resolve</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>
}

@code {
    private List<RoomVm> _rooms = [];
    private Dictionary<int, SensorReadingVm?> _latestReadings = new();
    private Dictionary<int, List<AlertVm>> _openAlerts = new();

    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        await LoadDataAsync();
        _ = AutoRefreshAsync(); // fire-and-forget: refresh the dashboard every 5s
    }

    // Polls Core every 5 seconds and re-renders, so the dashboard stays live
    // without a manual page reload. Stops when the component is disposed.
    private async Task AutoRefreshAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                await LoadDataAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* component disposed */ }
    }

    private async Task LoadDataAsync()
    {
        _rooms = await Api.GetRoomsAsync();
        foreach (var room in _rooms)
        {
            _latestReadings[room.Id] = await Api.GetLatestReadingAsync(room.Id);
            _openAlerts[room.Id] = await Api.GetAlertsAsync(room.Id, openOnly: true);
        }
    }

    private async Task ResolveAlert(int roomId, int alertId)
    {
        await Api.ResolveAlertAsync(roomId, alertId);
        await LoadDataAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
